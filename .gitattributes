# Keep repository text files normalized to LF unless explicitly overridden.
* text=auto eol=lf

# Windows scripts need CRLF when executed from cmd.exe/PowerShell.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Unix scripts and Gradle wrapper shell script should stay LF.
*.sh text eol=lf
gradlew text eol=lf

# Source and common resource/document formats.
*.java text eol=lf
*.kt text eol=lf
*.kts text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.md text eol=lf
*.snbt text eol=lf
*.mixins.json text eol=lf

# Binary assets and archives.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.jar binary
*.zip binary
*.gz binary
*.7z binary
*.class binary
